<script>
function pick(el){
  el.closest('.img-row').querySelectorAll('.opt').forEach(o=>o.classList.remove('selected'));
  el.classList.add('selected');
}
function exportAll(){
  const lines=[];
  document.querySelectorAll('.card').forEach(c=>{
    const sel=c.querySelector('.opt.selected');
    if(sel) lines.push(c.dataset.cat+'|'+c.dataset.name+'|'+sel.dataset.url);
  });
  const blob=new Blob([lines.join('\n')],{type:'text/plain'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='grv_selections.txt';
  a.click();
}
</script>

