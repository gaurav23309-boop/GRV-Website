<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>GRV Image Picker</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{background:#060d1a;color:#eaf0ff;font-family:'Segoe UI',sans-serif;padding:24px}
h1{text-align:center;color:#00bfa6;font-size:1.6rem;margin-bottom:4px}
.sub{text-align:center;color:rgba(255,255,255,.35);font-size:.8rem;margin-bottom:12px}
.top-btn{text-align:center;margin-bottom:30px}
button{background:#00bfa6;color:#fff;border:none;padding:11px 32px;border-radius:8px;font-size:.95rem;font-weight:700;cursor:pointer}
button:hover{background:#009d8b}
section{margin-bottom:36px;border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:20px;background:rgba(255,255,255,.015)}
section h2{font-size:1rem;color:#00bfa6;margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid rgba(255,255,255,.06)}
section h2 em{font-size:.75rem;color:rgba(255,255,255,.3);font-weight:400;font-style:normal}
.grid{display:flex;flex-wrap:wrap;gap:10px}
.card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:9px;padding:12px;width:420px}
.card-hd{display:flex;align-items:baseline;gap:6px;margin-bottom:8px;flex-wrap:wrap}
.card-hd b{font-size:.85rem;color:#e0eeff}
.card-hd small{font-size:.65rem;color:rgba(255,255,255,.3)}
.done{font-size:.6rem;background:rgba(0,191,166,.15);color:#00bfa6;padding:1px 6px;border-radius:4px;margin-left:auto}
.img-row{display:flex;gap:5px}
.opt{flex:1;background:rgba(255,255,255,.9);border-radius:6px;border:2px solid transparent;cursor:pointer;padding:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:160px;transition:.15s}
.opt img{max-width:100%;max-height:145px;object-fit:contain}
.opt span{font-size:.55rem;color:#555;margin-top:3px}
.opt.selected{border-color:#00bfa6;box-shadow:0 0 0 2px rgba(0,191,166,.3)}
.opt.err{opacity:.25}
.opt:hover{border-color:rgba(0,191,166,.5)}
.no-match{font-size:.7rem;color:rgba(255,255,255,.2);padding:8px;text-align:center;width:100%}
</style>
</head>
<body>
<h1>GRV Product Image Picker</h1>
<p class="sub">Click any image to select it (green border). When done, click Export.</p>
<div class="top-btn"><button onclick="exportAll()">Export Selections</button></div>
<section>
  <h2>S Type Load Cells <em>(12 products)</em></h2>
  <div class="grid"><div class="card" data-name="DYLY-101" data-cat="s-type">
  <div class="card-hd"><b>DYLY-101</b><small>0–20T</small><span class="done">✓</span></div>
  <div class="img-row"><div class="opt selected" data-url="https://iqrorwxhlqmmlq5m-static.micyjz.com/cloud/loBpqKnklqSRlkroimppjp/1.jpg" onclick="pick(this)">
  <img src="https://iqrorwxhlqmmlq5m-static.micyjz.com/cloud/loBpqKnklqSRlkroimppjp/1.jpg" loading="lazy" onerror="this.closest('.opt').classList.add('err')">
  <span>#1</span>
</div><div class="opt" data-url="https://iqrorwxhlqmmlq5m-static.micyjz.com/cloud/loBpqKnklqSRlkroimqmjp/2.jpg" onclick="pick(this)">
